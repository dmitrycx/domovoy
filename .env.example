# Telegram bot token from @BotFather (required)
BOT_TOKEN=123456789:replace-with-your-token

# Comma-separated Telegram user IDs allowed to run coordinator commands.
# Get yours by sending /whoami to the bot after the first start.
COORDINATOR_IDS=

# Where the SQLite file lives (default: data/domovoy.db; /data/domovoy.db in Docker)
DB_PATH=data/domovoy.db

# Weekly digest: every Monday at this local time…
DIGEST_TIME=09:00
# …in this IANA timezone
TZ=Europe/Belgrade
